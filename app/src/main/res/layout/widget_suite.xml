<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_suite"
    android:id="@+id/widget_suite_root">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:id="@+id/suite_title"
            android:text="SUITE // HOJE"
            android:textColor="#E5FF9900"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/suite_chip"
            android:text=" 4/6 "
            android:textColor="#FFB84D"
            android:textSize="8sp"
            android:textStyle="bold"
            android:background="@drawable/chip_suite"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:id="@+id/suite_time"
        android:text="12:30"
        android:textColor="#FF9900"
        android:textSize="38sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:includeFontPadding="false"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/suite_sub"
        android:text="1:1 com Elizia"
        android:textColor="#99FFFFFF"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="4dp"/>

</LinearLayout>
