<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_buddy"
    android:id="@+id/widget_buddy_root">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:id="@+id/buddy_title"
            android:text="BUDDY"
            android:textColor="#CC00E5FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/buddy_chip"
            android:text=" SYNC "
            android:textColor="#00E5FF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:background="@drawable/chip_buddy"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:id="@+id/buddy_time"
        android:text="16:48"
        android:textColor="#00E5FF"
        android:textSize="38sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:includeFontPadding="false"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/buddy_sub"
        android:text="> diga &quot;Buddy...&quot;"
        android:textColor="#99FFFFFF"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="4dp"/>

</LinearLayout>
