<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_palco"
    android:id="@+id/widget_palco_root">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:id="@+id/palco_title"
            android:text="PALCO"
            android:textColor="#CC00A8FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/palco_chip"
            android:text=" SHOW "
            android:textColor="#4AB7FF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:background="@drawable/chip_palco"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:id="@+id/palco_date"
        android:text="18/05"
        android:textColor="#4AB7FF"
        android:textSize="34sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:includeFontPadding="false"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/palco_sub"
        android:text="Garagem 66 - 21h"
        android:textColor="#99FFFFFF"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="4dp"/>

</LinearLayout>
